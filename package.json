                        },
                        {
                            "id": "elvish",
                            "file_extension": ".elv",
                            "vscode_extensions": [
                                "elves.elvish"
                            ]
                        },
                        {
                            "id": "vim-script",
                            "file_extension": ".vim",
                            "vscode_extensions": []
