                            "vscode_extensions": [
                                "Shopify.ruby-lsp"
                            ]
                        },
                        {
                            "id": "r",
                            "file_extension": ".r",
                            "vscode_extensions": [
                                "reditorsupport.r",
                                "reditorsupport.r-syntax"
                            ]
                        },
                        {
                            "id": "kotlin",
                            "file_extension": ".kt",
                            "vscode_extensions": [
                                "JetBrains.kotlin-server",
