{
    "name": "auto-install-vscode-extensions-for-opened-file",
    "displayName": "Auto Install VSCode Extensions for Opened File",
    "version": "0.0.60",
    "publisher": "willyhorizont",
    "icon": "icon.png",
    "author": "willyhorizont.github.io",
    "description": "Auto install VSCode extensions for opened file",
    "categories": [
        "Programming Languages",
        "Extension Packs",
        "Formatters"
    ],
    "engines": {
        "vscode": "^1.60.0"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./extension.js",
    "contributes": {
        "configuration": {
            "title": "Auto Install VSCode Extensions for Opened File",
            "properties": {
                "willyhorizont.github.io/auto-install-vscode-extensions-for-opened-file.language-specific-vscode-extensions": {
                    "type": "array",
                    "scope": "resource",
                    "markdownDescription": "Configuration mapping for language extensions. Local repo settings will take priority over global user settings.",
                    "default": [
                        {
                            "id": "powershell",
                            "file_extension": ".ps1",
                            "vscode_extensions": [
                                "ms-vscode.PowerShell"
                            ]
                        }
                    ],
                    "items": {
                        "type": "object",
                        "required": [
                            "id",
                            "file_extension",
                            "vscode_extensions"
                        ],
                        "properties": {
                            "id": {
                                "type": "string",
                                "description": "The identifier of the file extension"
                            },
                            "file_extension": {
                                "type": "string",
                                "description": "The file extension including the dot (e.g., .ps1)"
                            },
                            "vscode_extensions": {
                                "type": "array",
                                "description": "Array of extension IDs to install",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "willyhorizont.github.io/auto-install-vscode-extensions-for-opened-file.base-vscode-extensions": {
                    "type": "array",
                    "scope": "resource",
                    "markdownDescription": "List of core extension IDs that must always remain installed and whitelisted from automatic uninstallation.",
                    "default": [
                        "formulahendry.code-runner"
                    ],
                    "items": {
                        "type": "string"
                    }
                },
                "willyhorizont.github.io/auto-install-vscode-extensions-for-opened-file.ignored-file-extensions": {
                    "type": "array",
                    "scope": "resource",
                    "markdownDescription": "File extensions that will be ignored by this automation.",
                    "default": [
                        ".txt"
                    ],
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
