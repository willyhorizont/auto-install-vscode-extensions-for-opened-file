{
    "name": "auto-install-vscode-extensions-for-opened-file",
    "displayName": "Auto Install VSCode Extensions for Opened File",
    "version": "0.0.67",
    "publisher": "willyhorizont",
    "icon": "icon.png",
    "author": "willyhorizont.github.io",
    "description": "Auto install VSCode extensions for opened file",
    "categories": [
        "Programming Languages",
        "Extension Packs",
        "Formatters"
    ],
    "engines": {
        "vscode": "^1.60.0"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./extension.js",
    "contributes": {
        "configuration": {
            "title": "Auto Install VSCode Extensions for Opened File",
            "properties": {
                "willyhorizont.github.io/auto-install-vscode-extensions-for-opened-file.language-specific-vscode-extensions": {
                    "type": "array",
                    "scope": "resource",
                    "markdownDescription": "Configuration mapping for language extensions. Local repo settings will take priority over global user settings.",
                    "default": [
                        {
                            "id": "javascript-or-typescript",
                            "file_extension": ".js",
                            "vscode_extensions": []
                        },
                        {
                            "id": "python",
                            "file_extension": ".py",
                            "vscode_extensions": [
                                "ms-python.vscode-pylance"
                            ]
                        },
                        {
