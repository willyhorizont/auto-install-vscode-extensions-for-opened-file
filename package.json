                    ],
                    "items": {
                        "type": "object",
                        "required": [
                            "id",
                            "file_extension",
                            "vscode_extensions"
                        ],
                        "properties": {
                            "id": {
                                "type": "string",
                                "description": "The identifier of the file extension"
                            },
                            "file_extension": {
                                "type": "string",
                                "description": "The file extension including the dot (e.g., .ps1)"
                            },
                            "vscode_extensions": {
                                "type": "array",
                                "description": "Array of extension IDs to install",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "willyhorizont.github.io/auto-install-vscode-extensions-for-opened-file.base-vscode-extensions": {
                    "type": "array",
                    "scope": "resource",
                    "markdownDescription": "List of core extension IDs that must always remain installed and whitelisted from automatic uninstallation.",
                    "default": [
                        "ms-vscode.cpptools-themes",
                        "emmanuelbeziat.vscode-great-icons",
                        "aaron-bond.better-comments",
                        "adpyke.codesnap",
                        "cardinal90.multi-cursor-case-preserve",
                        "christian-kohler.path-intellisense",
                        "ecmel.vscode-html-css",
                        "formulahendry.code-runner",
                        "pokey.parse-tree",
                        "AllemandInstable.colorful-comments-refreshed",
                        "tobermory.es6-string-html",
                        "zjcompt.es6-string-javascript",
                        "mechatroner.rainbow-csv",
                        "naumovs.color-highlight",
                        "oderwat.indent-rainbow",
                        "jduponchelle.rainbow-end",
                        "ritwickdey.liveserver",
                        "yzhang.markdown-all-in-one",
                        "zignd.html-css-class-completion",
                        "mohd-akram.vscode-html-format"
                    ],
                    "items": {
                        "type": "string"
                    }
                },
                "willyhorizont.github.io/auto-install-vscode-extensions-for-opened-file.ignored-file-extensions": {
                    "type": "array",
                    "scope": "resource",
                    "markdownDescription": "File extensions that will be ignored by this automation.",
                    "default": [],
                    "items": {
                        "type": "string"
                    }
                }
